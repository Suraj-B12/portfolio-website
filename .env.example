# CloudFront distribution URL that fronts the S3 bucket holding /_next/static.
# Set this at build time on each EC2 instance so assetPrefix is baked into the
# compiled output. Leave it blank during local development.
NEXT_PUBLIC_ASSET_PREFIX=

# S3 bucket that holds the static assets. Read by scripts/deploy-assets.sh.
S3_ASSET_BUCKET=
